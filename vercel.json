{
    "functions": {
        "api/index.js": {
            "memory": 1024,
            "maxDuration": 30,
            "includeFiles": "node_modules/.prisma/client/**"
        },
        "api/debug-register.js": {
            "memory": 1024,
            "maxDuration": 30,
            "includeFiles": "node_modules/.prisma/client/**"
        }
    },
    "rewrites": [
        {
            "source": "/api/debug-register",
            "destination": "/api/debug-register.js"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api/index.js"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}